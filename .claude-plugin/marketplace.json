{
  "name": "pip-boy",
  "owner": {
    "name": "Marius Serban"
  },
  "metadata": {
    "description": "Personal curated collection of Claude Code plugins",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "context7",
      "source": "./common/external_plugins/context7",
      "description": "Up-to-date, version-specific code documentation and examples for libraries",
      "version": "1.0.0",
      "author": {
        "name": "Upstash"
      },
      "homepage": "https://context7.com",
      "repository": "https://github.com/upstash/context7",
      "keywords": ["documentation", "context", "mcp", "libraries"],
      "category": "Common"
    },
    {
      "name": "wasteland-recon",
      "source": "./development/common/plugins/wasteland-recon",
      "description": "Codebase reconnaissance agent and skill for exploring unfamiliar projects",
      "version": "1.0.0",
      "author": {
        "name": "Marius Serban"
      },
      "homepage": "https://github.com/serban-marius/pip-boy",
      "repository": "https://github.com/serban-marius/pip-boy",
      "keywords": ["recon", "exploration", "architecture", "codebase", "agent", "skill"],
      "category": "Development Tools"
    },
    {
      "name": "frontend-design",
      "source": "./development/common/external_plugins/frontend-design",
      "description": "Create distinctive, production-grade frontend interfaces with high design quality. Avoids generic AI aesthetics.",
      "version": "1.0.0",
      "author": {
        "name": "Anthropic"
      },
      "homepage": "https://claude.com/plugins/frontend-design",
      "repository": "https://github.com/anthropics/claude-plugins-official",
      "keywords": ["frontend", "design", "ui", "ux", "aesthetics"],
      "category": "Development Tools"
    },
    {
      "name": "diagrams",
      "source": "./development/common/plugins/diagrams",
      "description": "Generate interactive visual flow diagrams as standalone HTML files using Mermaid.js",
      "version": "1.0.0",
      "author": {
        "name": "Marius Serban"
      },
      "homepage": "https://github.com/serban-marius/pip-boy",
      "repository": "https://github.com/serban-marius/pip-boy",
      "keywords": ["diagrams", "mermaid", "visualization", "architecture", "flowchart", "skill"],
      "category": "Development Tools"
    },
    {
      "name": "git-reset-on-clear",
      "source": "./common/plugins/git-reset-on-clear",
      "description": "SessionStart hook that checks out main and pulls latest when /clear is used",
      "version": "1.0.0",
      "author": {
        "name": "Marius Serban"
      },
      "homepage": "https://github.com/serban-marius/pip-boy",
      "repository": "https://github.com/serban-marius/pip-boy",
      "keywords": ["hook", "git", "clear", "reset", "session"],
      "category": "Common"
    },
    {
      "name": "caveman",
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman",
        "ref": "v1.6.0"
      },
      "description": "Ultra-compressed communication mode. Cuts ~75% of output tokens by making the assistant talk like a caveman, without losing technical accuracy.",
      "version": "1.6.0",
      "author": {
        "name": "Julius Brussee",
        "url": "https://github.com/JuliusBrussee"
      },
      "homepage": "https://juliusbrussee.github.io/caveman/",
      "repository": "https://github.com/JuliusBrussee/caveman",
      "keywords": ["tokens", "compression", "output", "hooks", "skill", "productivity"],
      "category": "Common"
    }
  ]
}
